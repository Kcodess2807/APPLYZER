# Basic app settings
PROJECT_NAME=APPLYZER
ENVIRONMENT=development
DEBUG=true
BACKEND_CORS_ORIGINS=http://localhost:5173,http://localhost:3000,http://localhost:8000,http://127.0.0.1:5173

# Database settings
DATABASE_URL=postgresql://user:password@localhost:5432/dbname
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_KEY=your-supabase-service-key

# Redis settings
REDIS_URL=redis://localhost:6379/0

# AI Service settings 
OPENAI_API_KEY=your-openai-api-key
GROQ_API_KEY=your-groq-api-key

# GitHub API - token increases rate limit from 60 to 5000 req/hr
GITHUB_TOKEN=your-github-token

# Gmail API settings
GMAIL_CLIENT_ID=your-gmail-client-id
GMAIL_CLIENT_SECRET=your-gmail-client-secret
API_BASE_URL=http://localhost:8000

# Google Sheets API settings
SHEETS_CLIENT_ID=your-sheets-client-id
SHEETS_CLIENT_SECRET=your-sheets-client-secret
SHEETS_SPREADSHEET_ID=your-sheets-spreadsheet-id

# Follow-up settings
FOLLOWUP_DAYS_INTERVAL=7
MAX_FOLLOWUP_COUNT=2
REPLY_CHECK_INTERVAL_MINUTES=30

# Security settings
SECRET_KEY=your-super-secret-key-change-this-in-production
REQUIRE_AUTH=false
SUPABASE_JWT_SECRET=your-supabase-jwt-secret

# Logging settings
LOG_LEVEL=INFO
